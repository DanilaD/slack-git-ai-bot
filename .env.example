# ============================================================
# .env — SECRET TOKENS ONLY
# Non-secret settings live in config/ai.js, config/github.js, config/jira.js
# Copy this file to .env and fill in your values
# ============================================================

# Slack — from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# GitHub — from github.com/settings/tokens (needs repo + read:org scope)
GITHUB_TOKEN=ghp_your-github-token-here

# AI — add the key for whichever provider is set in config/ai.js
GROQ_API_KEY=gsk_your-groq-key-here
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Jira — from id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your-jira-api-token-here

# Server
PORT=3000
