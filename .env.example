# ============================================================
# Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Slack — from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# GitHub — from github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_REPO=owner/repo-name

# AI Provider — add the key for whichever provider you set in config/ai.js
# Default is Groq (free tier). Sign up at console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Jira — from id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your-jira-api-token-here
JIRA_PROJECT=YOUR_PROJECT_KEY

# Server
PORT=3000
