{
  "name": "slack-git-ai-bot",
  "version": "2.0.0",
  "description": "Slack bot that answers project questions using AI + GitHub",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src config",
    "lint:fix": "eslint src config --fix",
    "format": "prettier --write \"src/**/*.js\" \"config/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"config/**/*.js\"",
    "prepare": "husky",
    "test": "jest --testPathPatterns=tests/ --forceExit",
    "test:coverage": "jest --testPathPatterns=tests/ --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "clearMocks": true,
    "resetModules": false,
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@slack/web-api": "^7.0.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "husky": "^9.0.0",
    "jest": "^30.2.0",
    "lint-staged": "^15.0.0",
    "nock": "^14.0.11",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
